# VA Claim Navigator — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to source control.

# ── Insforge Backend ─────────────────────────────────────────────────────────
# Get your project URL and anon key from the Insforge project dashboard.
INSFORGE_API_BASE_URL=https://your-project-id.us-west.insforge.app
INSFORGE_ANON_KEY=ik_your_insforge_anon_key_here

# ── Stripe Payments ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use TEST keys (pk_test_ / sk_test_) for development; LIVE keys for production only.
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Stripe Price IDs (from your Stripe Products dashboard)
STRIPE_PRICE_ID_PRO=price_your_pro_price_id_here
STRIPE_PRICE_ID_DELUXE=price_your_deluxe_price_id_here

# ── Database (Optional — Insforge is the primary store) ──────────────────────
# Only needed if you use the Drizzle/PostgreSQL integration.
# DATABASE_URL=postgresql://user:password@host:5432/va_claim_navigator

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# HOST=0.0.0.0

# ── Vercel (set automatically by Vercel, not needed locally) ─────────────────
# VERCEL_URL=your-deployment.vercel.app
